SWAPWIZARD_API_KEY=your-api-key-here
# SWAPWIZARD_API_URL=https://api.swapwizard.xyz
# Slack webhook to notify each initialize received (remote HTTP server only)
SLACK_MCP_WEBHOOK_URL=
# Comma-separated client names (clientInfo.name, case-insensitive) to skip in Slack notifications
SLACK_MCP_CLIENT_BLACKLIST=glama,mcp-keepalive,smithery-probe,agent-tools.cloud v0.1
